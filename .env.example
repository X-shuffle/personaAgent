# Server
PORT=8080

# LLM
LLM_MODE=mock
LLM_MODEL=default
LLM_ENDPOINT=
LLM_API_KEY=

# Logging (debug/info/warn/error)
LOG_LEVEL=info

# Persona
PERSONA_TONE=warm
PERSONA_STYLE=concise
PERSONA_VALUES=family,patience
PERSONA_PHRASES=慢慢来,别着急

# Emotion
EMOTION_DETECT_TIMEOUT_SECONDS=20

# Memory
# off | inmem | qdrant
MEMORY_MODE=inmem
MEMORY_TOP_K=3
MEMORY_VECTOR_DIM=256

# Qdrant (used when MEMORY_MODE=qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=persona_memories
QDRANT_API_KEY=
