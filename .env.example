# Server
PORT=8080
# 服务监听端口。

# LLM
LLM_MODE=mock
# LLM 调用模式：mock（本地假实现）或 http（真实上游）。
LLM_MODEL=default
# LLM 模型名，透传给上游接口。
LLM_PROVIDER=generic
# LLM 提供商标识（如 generic/minimax/openai），用于 provider-aware 兼容策略。
LLM_TOOL_PAYLOAD_NORMALIZATION=auto
# 工具消息规范化策略：auto|on|off。
LLM_ENDPOINT=
# LLM 上游地址（http 模式必填）。
LLM_API_KEY=
# LLM 上游鉴权密钥（http 模式通常必填）。
LLM_TIMEOUT_SECONDS=20
# 单次 LLM HTTP 请求超时（秒）。

# Logging (debug/info/warn/error)
LOG_LEVEL=info
# 日志级别，debug 最详细。

# Persona
PERSONA_TONE=warm
# 人设语气。
PERSONA_STYLE=concise
# 人设表达风格。
PERSONA_VALUES=family,patience
# 人设价值观（逗号分隔）。
PERSONA_PHRASES=慢慢来,别着急
# 人设常用短语（逗号分隔）。

# Emotion
# rule | llm
EMOTION_DETECTOR_MODE=rule
# 情绪识别模式：rule（规则）或 llm（模型）。
EMOTION_DETECT_TIMEOUT_SECONDS=20
# 情绪识别超时（秒）。

# Memory
MEMORY_TOP_K=3
# 每次检索返回的候选记忆条数上限。
MEMORY_VECTOR_DIM=1024
# 向量维度，必须与 embedding 输出和 Qdrant collection 维度一致。
MEMORY_SIMILARITY_THRESHOLD=0
# 相似度阈值，低于该值的候选会被过滤。
MEMORY_EMBED_ENDPOINT=https://ai.gitee.com/v1/embeddings
# embedding API 地址（必填）。
MEMORY_EMBED_API_KEY=
# embedding API 鉴权密钥。
MEMORY_EMBED_MODEL=bge-large-zh-v1.5
# embedding 模型名。
MEMORY_EMBED_TIMEOUT_SECONDS=15
# 单次 embedding HTTP 请求超时（秒）。
MEMORY_SHORT_TERM_SIZE=3
# 短期记忆上下文数量（user+assistant 算一条）。

# Qdrant
QDRANT_URL=http://localhost:6333
# Qdrant 服务地址。
QDRANT_COLLECTION=persona_memories
# 记忆向量写入/检索的 collection 名。
QDRANT_API_KEY=
# Qdrant 鉴权密钥（如开启鉴权则需配置）。

# Ingestion
INGEST_ENABLED=true
# 是否启用 /ingest 数据摄入能力。
INGEST_MAX_UPLOAD_BYTES=10485760
# /ingest 单次上传大小上限（字节）。
INGEST_ALLOWED_EXTENSIONS=txt,json
# 允许上传的文件扩展名（逗号分隔）。
# Deprecated alias (still supported): INGEST_ALLOWED_EXT
INGEST_EMBED_BATCH_SIZE=64
# 摄入时 embedding 批处理大小。
INGEST_SEGMENT_MAX_CHARS=500
# 单个分段最大字符数。
INGEST_SEGMENT_MERGE_WINDOW_SECONDS=90
# 相邻消息在该时间窗内会尝试合并分段（秒）。

# MCP
MCP_SETTINGS_PATH=mcp_settings.json
# MCP 配置文件路径（标准 mcp_settings.json 结构）。
MCP_SETTINGS_REQUIRED=false
# true 时要求配置文件必须存在，否则启动失败。
TOOL_MAX_EXEC_ROUNDS=3
# 工具规划/执行最多轮数上限（<=0 会回退为默认值）。
